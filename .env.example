# ===========================================
# Copy to .env and fill in your values
# For Railway: set these as environment variables
# ===========================================

# Required: Anthropic API key (Claude for copy generation, QA, gap analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Gemini API key (for research features)
GEMINI_API_KEY=

# Optional: Perplexity API key (for research features)
PERPLEXITY_API_KEY=

# Optional: CORS origins (comma-separated). Use * for production or add your Railway URL
# Example: https://your-app.railway.app,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: Database URL (Railway Postgres or keep SQLite for simple deploys)
# DATABASE_URL=sqlite:///./data/copywrite.db

# Optional: Paths (defaults work for Docker/Railway)
# CHROMA_PERSIST_PATH=./data/chroma
# UPLOAD_DIR=./data/uploads
